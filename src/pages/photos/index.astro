---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedCollection } from "../../lib/content";

const photos = await getPublishedCollection("photos");
---

<BaseLayout title="照片 | JiangXy's Notes" description="一些被认真保存下来的画面。">
  <section class="section-block">
    <div class="section-heading">
      <h1>照片墙</h1>
      <p>一些被认真保存下来的画面。</p>
    </div>
    <div class="photo-grid photo-grid-large">
      {photos.map((photo) => (
        <a class="photo-card" href={`/photos/${photo.id}`}>
          <img src={photo.data.image} alt={photo.data.title} loading="lazy" />
          <div class="photo-card-copy">
            <strong>{photo.data.title}</strong>
            <span>{photo.data.location ?? "未知地点"}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
