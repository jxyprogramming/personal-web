---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedCollection } from "../../lib/content";

const notes = await getPublishedCollection("notes");
---

<BaseLayout title="学而时习 | JiangXy's Notes" description="整理课程笔记和学习探讨。">
  <section class="section-block">
    <div class="section-heading">
      <h1>学习笔记</h1>
      <p>这里有课程笔记和学习讨论。</p>
    </div>
    <div class="card-grid">
      {notes.map((note) => (
        <PostCard
          href={`/notes/${note.id}`}
          eyebrow={note.data.course}
          title={note.data.title}
          description={note.data.description}
          meta={`${note.data.semester} · ${note.data.publishedAt.toLocaleDateString("zh-CN")}`}
          tags={note.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
