---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A personal space for notes, essays, and photos."
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href="/">JiangXy's Notes</a>
        <nav class="site-nav">
          <a href="/notes">学习笔记</a>
          <a href="/posts">随笔</a>
          <a href="/photos">相册</a>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <p>问渠那得清如许，为有源头活水来。</p>
      </footer>
    </div>

    <script>
      const initCodeBlocks = () => {
        const blocks = document.querySelectorAll("pre.astro-code");

        blocks.forEach((block) => {
          if (!(block instanceof HTMLElement) || block.dataset.enhanced === "true") {
            return;
          }

          block.dataset.enhanced = "true";

          const language = (block.dataset.language || "code").toLowerCase();
          const wrapper = document.createElement("div");
          wrapper.className = "code-block-shell";

          const toolbar = document.createElement("div");
          toolbar.className = "code-block-toolbar";

          const badge = document.createElement("span");
          badge.className = "code-block-language";
          badge.textContent = language;

          const button = document.createElement("button");
          button.type = "button";
          button.className = "code-block-copy";
          button.textContent = "复制";

          button.addEventListener("click", async () => {
            const text = block.textContent ?? "";

            try {
              await navigator.clipboard.writeText(text);
              button.textContent = "已复制";
              window.setTimeout(() => {
                button.textContent = "复制";
              }, 1600);
            } catch {
              button.textContent = "复制失败";
              window.setTimeout(() => {
                button.textContent = "复制";
              }, 1600);
            }
          });

          toolbar.append(badge, button);
          block.parentNode?.insertBefore(wrapper, block);
          wrapper.append(toolbar, block);
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCodeBlocks);
      } else {
        initCodeBlocks();
      }
    </script>
  </body>
</html>
